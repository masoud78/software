# PostgreSQL connection string
# روی Vercel این متغیر را در تنظیمات پروژه (Settings > Environment Variables) تنظیم کنید
# مثال Vercel Postgres:
# postgresql://default:xxxxxxxx@ep-xxx-pooler.region.aws.neon.tech/verceldb?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
JWT_SECRET="content-platform-super-secret-key-2026-change-in-production"
NEXT_PUBLIC_APP_NAME="پلتفرم مدیریت محتوا"